# ============================================
# Semi-Intel Configuration
# ============================================
# 1. FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html 에서 무료 발급
# 2. 이 파일을 .env 로 복사 후 키 입력
#    cp .env.example .env

FRED_API_KEY=your_fred_api_key_here

# Phase 4: AI Advisory — LLM 프로바이더 선택
# 3가지 중 하나 선택: google / anthropic / openai
LLM_PROVIDER=google

# Google Gemini (기본) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
# LLM_MODEL=gemini-2.0-flash

# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-sonnet-4-20250514

# OpenAI GPT — https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_MODEL=gpt-4o

# Database (기본: SQLite, PostgreSQL 전환 시 아래 설정)
DB_TYPE=sqlite
DB_PATH=./data/semi_intel.db
# DB_TYPE=postgresql
# DB_URL=postgresql://user:password@localhost:5432/semi_intel

# Data directory
DATA_DIR=./data

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
